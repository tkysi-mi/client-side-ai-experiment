{
  "name": "client-side-ai-learning-lab",
  "version": "2.0.0",
  "private": true,
  "description": "EdTech experiments with client-side language models",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/copy-vad-assets.mjs",
    "predev": "node scripts/copy-vad-assets.mjs",
    "dev": "vite",
    "prebuild": "node scripts/copy-vad-assets.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@ricky0123/vad-web": "^0.0.30",
    "@types/dom-chromium-ai": "^0.0.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "onnxruntime-web": "^1.27.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.0.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^27.2.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "author": "takeyoshi-mi",
  "license": "MIT"
}
